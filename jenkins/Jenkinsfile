// =============================================================================
// FMS Live Surface — Jenkins Declarative Pipeline
//
// Single pipeline for both hourly and daily runs:
//   - 00:00–00:59 AM  →  DAILY path  (daily_merge_runner)
//   - 01:00–23:59     →  HOURLY path (parallel site runners + finalize)
//
// Jenkins global variables required:
//   ArcPy3       — full path to ArcGIS Pro Python executable
//                  e.g. C:\Program Files\ArcGIS\Pro\bin\Python\envs\arcgispro-py3\python.exe
//   ENV          — deployment environment label  (NPE | PROD)
//
// Credentials required (Manage Jenkins > Credentials):
//   GITLAB_TOKEN — Secret text: GitLab personal access token
//
// To add a new mine site: append its code to FMS_SITES below. No other changes needed.
// =============================================================================

// ── Site list ─────────────────────────────────────────────────────────────────
def FMS_SITES = ['WB', 'ER', 'SF', 'YND', 'JB', 'NWW', 'MAC']

pipeline {
    agent any

    // Runs every hour at 15 past. Adjust the minute to suit your schedule.
    triggers { cron('15 * * * *') }

    parameters {
        string(
            name: 'FMS_FORCE_DATE',
            defaultValue: '',
            description: 'Optional: Force a specific processing date (YYYYMMDD). Leave blank to use today. Used for manual reruns of a past date.'
        )
    }

    environment {
        // ── Repo URLs — update with actual GitLab paths before go-live ────────
        CONFIG_REPO_URL     = 'https://gitlab.example.com/waio/fms-config.git'
        AUTOMATION_REPO_URL = 'https://gitlab.example.com/waio/fms-live-surface.git'

        // ── Derived from Jenkins global variables ─────────────────────────────
        // %ArcPy3%   is referenced directly in bat steps
        // %ENV%      is referenced directly in bat steps
        // Both are set in Manage Jenkins > Configure System > Global properties
    }

    stages {

        // ── Stage 1: Determine run mode and compute shared timestamp ──────────
        stage('Determine Run Mode') {
            steps {
                script {
                    def now     = new Date()
                    def hour    = now.format('H').toInteger()
                    def hourStr = now.format('HH')

                    // Use FMS_FORCE_DATE if provided, otherwise today's date
                    def baseDate = params.FMS_FORCE_DATE?.trim() ?: now.format('yyyyMMdd')

                    // Shared run timestamp passed to all site runners and finalize
                    env.RUN_TIMESTAMP = "${baseDate}${hourStr}0000"

                    // 00:00–00:59 AM → daily merge; all other hours → hourly pipeline
                    env.IS_DAILY = (hour == 0) ? 'true' : 'false'

                    echo "Mode         : ${env.IS_DAILY == 'true' ? 'DAILY' : 'HOURLY'}"
                    echo "Run timestamp: ${env.RUN_TIMESTAMP}"
                    echo "Force date   : ${params.FMS_FORCE_DATE ?: '(none)'}"
                }
            }
        }

        // ── Stage 2: Clean workspace ──────────────────────────────────────────
        // Requires the Jenkins "Workspace Cleanup" plugin
        stage('Clean Workspace') {
            steps { cleanWs() }
        }

        // ── Stage 3: Clone repositories ───────────────────────────────────────
        // Config repo: use NPE/ sub-folder for config files
        // Automation repo: FMS Live Surface Python pipeline
        stage('Clone Repositories') {
            steps {
                script {
                    withCredentials([string(credentialsId: 'GITLAB_TOKEN', variable: 'TOKEN')]) {
                        // Strip protocol to inject the token between https:// and the host
                        def configHost     = env.CONFIG_REPO_URL.replace('https://', '')
                        def automationHost = env.AUTOMATION_REPO_URL.replace('https://', '')

                        bat "git clone --depth 1 https://oauth2:%TOKEN%@${configHost} config_repo"
                        bat "git clone --depth 1 https://oauth2:%TOKEN%@${automationHost} automation"
                    }
                }
            }
        }

        // ── Stage 4: Hourly — parallel site pipelines ─────────────────────────
        // Each site runs fms_runner independently. failFast=false so one site
        // failure does not cancel the others.
        stage('Run Site Pipelines') {
            when { expression { env.IS_DAILY == 'false' } }
            steps {
                script {
                    def parallelStages = [failFast: false]

                    // Common CLI fragments reused by every site
                    def configArgs  = "--config ..\\config_repo\\NPE\\app_config.yaml" +
                                      " --logging ..\\config_repo\\NPE\\logging.yaml"
                    def forceArg    = params.FMS_FORCE_DATE?.trim()
                                      ? " --FMS_ForceDate ${params.FMS_FORCE_DATE.trim()}"
                                      : ''

                    FMS_SITES.each { site ->
                        def s = site  // capture loop variable for closure
                        parallelStages[s] = {
                            dir('automation') {
                                bat "\"%ArcPy3%\" -m src.runners.fms_runner" +
                                    " ${configArgs}" +
                                    " --site ${s}" +
                                    " --env %ENV%" +
                                    " --FMS_RunTimestamp %RUN_TIMESTAMP%" +
                                    forceArg
                            }
                        }
                    }

                    parallel parallelStages
                }
            }
        }

        // ── Stage 5: Hourly — finalize (merge boundaries + FME INGEST) ────────
        // Runs once after ALL parallel site stages have completed.
        stage('Finalize') {
            when { expression { env.IS_DAILY == 'false' } }
            steps {
                script {
                    dir('automation') {
                        bat "\"%ArcPy3%\" -m src.runners.fms_finalize_runner" +
                            " --config ..\\config_repo\\NPE\\app_config.yaml" +
                            " --logging ..\\config_repo\\NPE\\logging.yaml" +
                            " --run-timestamp %RUN_TIMESTAMP%" +
                            " --env %ENV%"
                    }
                }
            }
        }

        // ── Stage 6: Daily — mosaic hourly TIFFs + FME INGEST daily ──────────
        // Triggered only in the 00:00–00:59 AM window.
        // Mosaics all hourly FMS_<date>HH0000/ outputs into FMS_<date>/ then
        // calls FME INGEST (SITE=Daily) and deletes the hourly folders.
        stage('Daily Merge') {
            when { expression { env.IS_DAILY == 'true' } }
            steps {
                script {
                    dir('automation') {
                        def forceArg = params.FMS_FORCE_DATE?.trim()
                                       ? " --FMS_ForceDate ${params.FMS_FORCE_DATE.trim()}"
                                       : ''
                        bat "\"%ArcPy3%\" -m src.runners.daily_merge_runner" +
                            " --config ..\\config_repo\\NPE\\app_config.yaml" +
                            " --logging ..\\config_repo\\NPE\\logging.yaml" +
                            " --env %ENV%" +
                            forceArg
                    }
                }
            }
        }
    }

    post {
        failure {
            echo "FMS pipeline FAILED — ${env.JOB_NAME} #${env.BUILD_NUMBER} " +
                 "(Mode: ${env.IS_DAILY == 'true' ? 'DAILY' : 'HOURLY'}, " +
                 "Timestamp: ${env.RUN_TIMESTAMP})"
        }
        always {
            cleanWs()
        }
    }
}
